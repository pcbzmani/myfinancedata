# Backend — copy this to backend/.env
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
PORT=5000
CLIENT_URL=http://localhost:3000

# No DATABASE_URL needed — data is stored locally in backend/prisma/finance.db (SQLite)

# Frontend — copy this to frontend/.env
VITE_API_URL=http://localhost:5000/api/v1
