generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./finance.db"
}

model Transaction {
  id          String   @id @default(uuid())
  type        String   // income | expense
  category    String
  amount      Float
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
}

model Investment {
  id             String   @id @default(uuid())
  type           String   // stocks | mutual_fund | crypto | fd | ppf | other
  name           String
  amountInvested Float
  currentValue   Float
  units          Float?
  buyPrice       Float?
  date           DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Insurance {
  id           String   @id @default(uuid())
  type         String   // health | life | vehicle | home | term
  provider     String
  policyNumber String?
  premium      Float
  frequency    String   // monthly | quarterly | yearly
  sumAssured   Float
  startDate    DateTime
  endDate      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Settings {
  id         String @id @default("default")
  aiProvider String @default("anthropic")
  aiApiKey   String @default("")
  aiModel    String @default("claude-haiku-4-5-20251001")
}
